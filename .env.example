# --- DB ---
# SQLite (lokal, default fuer v0.1)
DATABASE_URL=file:./runs/leadgen.db
# Postgres (v0.2 deploy):
# DATABASE_URL=postgres://user:pass@host:5432/leadgen

# --- External APIs ---
# Google Maps Places (New) API
GOOGLE_MAPS_API_KEY=
# PageSpeed Insights API (gleicher Key wie Maps moeglich, separater empfohlen)
PAGESPEED_API_KEY=
# Anthropic (Opportunity-Agent)
ANTHROPIC_API_KEY=

# --- OSM Overpass (primaere freie Quelle) ---
# Hauptserver (Alternative-Mirrors bei Bedarf: kumi.systems, z.overpass-api.de)
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
# Pflicht laut OSM Usage Policy - identifizierbarer UA mit Kontakt
OVERPASS_USER_AGENT=farne-leadgen/0.1 (+https://farne-solutions.com; contact@farne-solutions.com)
# Defensive Obergrenze pro Run (Schutz gegen Endlosloops)
OVERPASS_MAX_REQUESTS_PER_RUN=40
# Server-seitiges Timeout (Overpass [timeout:N])
OVERPASS_TIMEOUT_SECONDS=180
# Lokaler Response-Cache
OVERPASS_CACHE_DIR=./runs/overpass-cache
# 14 Tage TTL
OVERPASS_CACHE_TTL_DAYS=14
# Minimaler Delay zwischen zwei Overpass-Queries (ms) - Usage Policy Hoeflichkeit
OVERPASS_MIN_DELAY_MS=1500

# --- Pipeline ---
LEADGEN_CITY=Vienna
LEADGEN_LOG_LEVEL=info
