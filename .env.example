# --- DB ---
# SQLite (lokal, default fuer v0.1)
DATABASE_URL=file:./runs/leadgen.db
# Postgres (v0.2 deploy):
# DATABASE_URL=postgres://user:pass@host:5432/leadgen

# --- External APIs ---
# Google APIs - ein Key fuer drei Services (PageSpeed Insights, Places, CSE).
# v0.2 konsolidiert auf GOOGLE_API_KEY; die Legacy-Aliase
# (GOOGLE_MAPS_API_KEY, PAGESPEED_API_KEY) bleiben akzeptiert.
GOOGLE_API_KEY=
# Custom Search Engine ID (erforderlich fuer CSE-basiertes Website-Discovery)
GOOGLE_CSE_ID=
# Legacy-Aliase - koennen gesetzt bleiben, GOOGLE_API_KEY hat Vorrang.
# GOOGLE_MAPS_API_KEY=
# PAGESPEED_API_KEY=
# Anthropic (Opportunity-Agent)
ANTHROPIC_API_KEY=

# --- OSM Overpass (primaere freie Quelle) ---
# Hauptserver (Alternative-Mirrors bei Bedarf: kumi.systems, z.overpass-api.de)
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
# Pflicht laut OSM Usage Policy - identifizierbarer UA mit Kontakt
OVERPASS_USER_AGENT=farne-leadgen/0.1 (+https://farne-solutions.com; contact@farne-solutions.com)
# Defensive Obergrenze pro Run (Schutz gegen Endlosloops)
OVERPASS_MAX_REQUESTS_PER_RUN=40
# Server-seitiges Timeout (Overpass [timeout:N])
OVERPASS_TIMEOUT_SECONDS=180
# Lokaler Response-Cache
OVERPASS_CACHE_DIR=./runs/overpass-cache
# 14 Tage TTL
OVERPASS_CACHE_TTL_DAYS=14
# Minimaler Delay zwischen zwei Overpass-Queries (ms) - Usage Policy Hoeflichkeit
OVERPASS_MIN_DELAY_MS=1500

# --- Audit-Pipeline ---
# Per-Request Timeout fuer Website-Fetch (ms)
AUDIT_FETCH_TIMEOUT_MS=30000
# Zusaetzliche Retries bei transienten Fehlern
AUDIT_FETCH_RETRIES=2
# Paralleler Audit-Worker-Pool
AUDIT_CONCURRENCY=10
# User-Agent fuer Audit-Fetcher (identifizierbar + Kontakt)
AUDIT_USER_AGENT=farne-leadgen-audit/0.1 (+https://farne-solutions.com; contact@farne-solutions.com)
# Minimum Delay pro Host zwischen zwei Requests (ms) - Politeness
AUDIT_MIN_DELAY_PER_HOST_MS=1000
# robots.txt respektieren (true|false|1|0)
AUDIT_RESPECT_ROBOTS_TXT=true
# Cache-TTL fuer statische Signale (Tage)
AUDIT_STATIC_TTL_DAYS=30
# Cache-TTL fuer PageSpeed-Insights-Signale (Tage, kuerzer wegen Volatilitaet)
AUDIT_PSI_TTL_DAYS=14

# --- Website-Discovery ---
# DNS-Probe fuer Website-URL (name.at, name.com ...) an/aus
DNS_PROBE_ENABLED=true
# Zu pruefende TLDs, komma-separiert
DNS_PROBE_TLDS=at,com
# Custom-Search-Engine als Fallback (erfordert GOOGLE_API_KEY + GOOGLE_CSE_ID)
CSE_DISCOVERY_ENABLED=false
# Max Queries pro Candidate bei CSE-Discovery (Budget-Schutz)
CSE_MAX_QUERIES_PER_CANDIDATE=3

# --- Pipeline ---
LEADGEN_CITY=Vienna
LEADGEN_LOG_LEVEL=info
